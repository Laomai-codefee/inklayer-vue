{
    "name": "inklayer-vue",
    "version": "1.0.13",
    "description": "PDF viewer and annotation SDK for Vue 3 applications, with comments, collaborative permissions, and PDF/Excel export.",
    "type": "module",
    "keywords": [
        "pdf",
        "pdf-viewer",
        "pdf-reader",
        "pdf-annotation",
        "pdf-annotator",
        "annotation",
        "viewer",
        "highlight",
        "markup",
        "comment",
        "review",
        "document-review",
        "collaboration",
        "annotation-permissions",
        "vue",
        "vue3",
        "vue-pdf",
        "sdk"
    ],
    "author": "Laomai<codefee@foxmail.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Laomai-codefee/inklayer-vue.git"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "bugs": {
        "url": "https://github.com/Laomai-codefee/inklayer-vue/issues"
    },
    "homepage": "https://inklayer.dev",
    "main": "./dist/index.cjs.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "browser": "./dist/index.es.js",
            "import": "./dist/index.es.js",
            "require": "./dist/index.cjs.js"
        },
        "./style": {
            "types": "./dist/style.d.ts",
            "default": "./dist/inklayer-vue.css"
        }
    },
    "files": [
        "dist",
        "README.md",
        "README-en-US.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite --mode playground --open",
        "build": "vue-tsc --noEmit && vite build && echo 'export {}' > dist/style.d.ts",
        "build:playground": "vite build --mode playground --base ./ --outDir docs",
        "preview": "vite preview --mode playground",
        "check:package": "node scripts/check-package.mjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@floating-ui/dom": "^1.7.4",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "exceljs": "^4.4.0",
        "file-saver": "^2.0.5",
        "konva": "^9.3.14",
        "pdf-lib": "^1.17.1",
        "pdfjs-dist": "~4.3.136",
        "pinia": "^2.1.7",
        "reka-ui": "^2.9.10",
        "tailwind-merge": "^2.3.0",
        "vue-i18n": "^10.0.0",
        "web-highlighter": "^0.7.4"
    },
    "peerDependencies": {
        "vue": "^3.5.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/vite": "^4.0.0",
        "@types/file-saver": "^2.0.7",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vitest/coverage-v8": "^1.6.0",
        "@vue/test-utils": "^2.4.6",
        "highlight.js": "^11.9.0",
        "jsdom": "^24.1.0",
        "postcss-prefix-selector": "^2.1.1",
        "sass-embedded": "^1.93.3",
        "shadcn-vue": "^2.7.4",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.3.0",
        "vite": "^5.4.0",
        "vite-plugin-dts": "^3.9.1",
        "vitest": "^1.6.0",
        "vue": "^3.5.0",
        "vue-tsc": "^2.2.0"
    }
}
