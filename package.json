{
  "name": "inklayer-vue",
  "version": "0.2.0",
  "description": "Extensible Vue 3 PDF annotation SDK and viewer built on PDF.js, supporting document review, comments, and annotation editing.",
  "type": "module",
  "author": "Laomai<codefee@foxmail.com>",
  "license": "MIT",
  "repository": {
        "type": "git",
        "url": "https://github.com/Laomai-codefee/inklayer-vue.git"
    },
    "bugs": {
        "url": "https://github.com/Laomai-codefee/inklayer-vue/issues"
    },
    "homepage": "https://github.com/Laomai-codefee/inklayer-vue#readme",
  "main": "./dist/inklayer-vue.cjs",
  "module": "./dist/inklayer-vue.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/inklayer-vue.mjs",
      "require": "./dist/inklayer-vue.cjs"
    },
    "./dist/inklayer-vue.css": "./dist/inklayer-vue.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --mode demo --open",
    "build": "vue-tsc --noEmit && vite build",
    "build:demo": "vite build --mode demo --base ./ --outDir docs",
    "preview": "vite preview --mode demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@vueuse/core": "^10.11.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "konva": "^9.3.14",
    "lucide-vue-next": "^0.344.0",
    "nanoid": "^5.1.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "~4.3.136",
    "pinia": "^2.1.7",
    "radix-vue": "^1.9.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.0",
    "vue-i18n": "^10.0.0",
    "web-highlighter": "^0.7.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/file-saver": "^2.0.7",
    "@vitejs/plugin-vue": "^5.0.0",
    "highlight.js": "^11.9.0",
    "postcss-prefix-selector": "^2.1.1",
    "sass-embedded": "^1.93.3",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.0",
    "shadcn-vue": "^2.7.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.2.0"
  }
}
